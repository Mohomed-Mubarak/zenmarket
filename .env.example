# ============================================================
# ZENMARKET — Environment Variables  (v29 — Full Stack)
# ============================================================
# SETUP:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in every value below
#   3. Run:              node build.js
#      → Generates js/env.js (browser-side public vars)
#   4. NEVER commit .env or js/env.js — both are in .gitignore
#
# VERCEL DEPLOYMENT:
#   Add ALL variables below in:
#   Project → Settings → Environment Variables
#   (Both "browser" vars from build.js AND server-only vars below)
#   The buildCommand in vercel.json runs `node build.js` automatically.
#
# VARIABLE SCOPES:
#   PUBLIC  → written into js/env.js, visible in the browser bundle
#   SERVER  → only used by Vercel Serverless Functions (/api), never in browser
# ============================================================


# ── Demo Mode ────────────────────────────────────────────────────────
# [PUBLIC]
# true  → localStorage email/password auth (local dev / demo, no DB needed)
# false → Supabase OTP magic-link auth + Supabase database (production)
DEMO_MODE=false


# ── Admin Credentials (DEMO_MODE=true only) ──────────────────────────
# [PUBLIC — only active when DEMO_MODE=true]
# In production (DEMO_MODE=false) Supabase handles all auth — these are ignored.
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeMe_Strong_Password_Here!


# ── Supabase — Browser (public) ──────────────────────────────────────
# [PUBLIC]
# 1. Create a project at https://supabase.com (choose Singapore region)
# 2. Go to Project Settings → API
# 3. Copy Project URL and the anon/public key
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE


# ── Supabase — Server (service role — NEVER expose to browser) ────────
# [SERVER ONLY — Vercel Serverless Functions only]
# Found in: Project Settings → API → service_role key
# WARNING: This key bypasses Row Level Security. Keep it secret.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE


# ── Vercel Serverless API — Admin Token ───────────────────────────────
# [SERVER ONLY]
# A strong random secret used to authenticate calls to /api/admin/*
# Generate one: openssl rand -hex 32
# The admin JS files send this in the X-Admin-Token header.
ADMIN_API_TOKEN=GENERATE_A_STRONG_RANDOM_SECRET_HERE


# ── Site URL (used by serverless functions for CORS + WA links) ───────
# [SERVER ONLY]
# Your live domain, no trailing slash
SITE_URL=https://yourdomain.com


# ── PayHere Payment Gateway ───────────────────────────────────────────
# [PUBLIC — merchant ID] + [SERVER ONLY — merchant secret]
# 1. Register at https://payhere.lk
# 2. Merchant ID:     Settings → Merchant → Merchant ID
# 3. Merchant Secret: Settings → Merchant → Merchant Secret (for IPN)
# 4. Set Notify URL in PayHere dashboard → https://yourdomain.com/api/payhere-webhook
# Set PAYHERE_SANDBOX=false only when going live
PAYHERE_MERCHANT_ID=YOUR_PAYHERE_MERCHANT_ID
PAYHERE_MERCHANT_SECRET=YOUR_PAYHERE_MERCHANT_SECRET
PAYHERE_SANDBOX=false


# ── WhatsApp Business ─────────────────────────────────────────────────
# [PUBLIC — phone numbers] + [SERVER ONLY — API credentials]

# Admin notification numbers (international format, no +)
WA_PHONE=94771234567
WA_PHONE_2=94751234567

# WhatsApp Business Cloud API (Meta) — optional, for server-side sending
# If not set, /api/whatsapp returns wa.me links instead (link mode)
# Mode: "cloud" = Meta Business API | "link" = wa.me link fallback (default)
WHATSAPP_MODE=link
# Required only when WHATSAPP_MODE=cloud:
# WHATSAPP_ACCESS_TOKEN=YOUR_META_WHATSAPP_ACCESS_TOKEN
# WHATSAPP_PHONE_NUMBER_ID=YOUR_META_PHONE_NUMBER_ID


# ── PostHog Analytics ─────────────────────────────────────────────────
# [PUBLIC]
# Leave blank to disable analytics entirely.
# Get your key at https://posthog.com → Project Settings → Project API Key
POSTHOG_KEY=
POSTHOG_HOST=https://app.posthog.com


# ── EmailJS (contact form emails) ─────────────────────────────────────
# [PUBLIC]
# 1. Sign up at https://emailjs.com
# 2. Add an Email Service (Gmail, Outlook, SMTP, etc.)
# 3. Create a template using variables:
#      {{from_name}} {{from_email}} {{phone}} {{subject}} {{message}} {{reply_to}}
# 4. Copy the three IDs from your EmailJS dashboard:
EMAILJS_PUBLIC_KEY=YOUR_EMAILJS_PUBLIC_KEY
EMAILJS_SERVICE_ID=YOUR_EMAILJS_SERVICE_ID
EMAILJS_TEMPLATE_ID=YOUR_EMAILJS_TEMPLATE_ID
EMAILJS_ADMIN_EMAIL=admin@yourdomain.com
